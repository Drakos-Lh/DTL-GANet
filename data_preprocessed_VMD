# =========================================================
# 3. VMD 分解
# =========================================================
def decompose_segment_with_vmd(data_scaled: np.ndarray, cfg: Config):
    """
    输入:
        data_scaled: (T, N)

    输出:
        lowmid_all: (T, N, K-1)
        high_all:   (T, N, 1)
        omega_all:  (N, K)
    """
    T, N = data_scaled.shape

    lowmid_list = []
    high_list = []
    omega_all = []

    print(f"\n开始 VMD 分解，序列长度 = {T}")

    for farm in range(N):
        print(f"风电场 {farm + 1}/{N}")

        signal = data_scaled[:, farm]

        u, u_hat, omega = VMD(
            signal,
            alpha=cfg.alpha,
            tau=cfg.tau,
            K=cfg.K,
            DC=cfg.DC,
            init=cfg.init,
            tol=cfg.tol
        )

        # u: (K, T) -> (T, K)
        u = u.T

        omega_final = omega[-1]
        order = np.argsort(omega_final)
        omega_sorted = omega_final[order]

        print("排序后中心频率:", omega_sorted)

        u = u[:, order]

        # 低中频 = 除最高频之外
        lowmid = u[:, :-1]   # (T, K-1)
        high = u[:, -1:]     # (T, 1)

        lowmid_list.append(lowmid)
        high_list.append(high)
        omega_all.append(omega_sorted)

    lowmid_all = np.stack(lowmid_list, axis=1).astype(np.float32)  # (T, N, K-1)
    high_all = np.stack(high_list, axis=1).astype(np.float32)      # (T, N, 1)
    omega_all = np.stack(omega_all, axis=0).astype(np.float32)     # (N, K)

    return lowmid_all, high_all, omega_all


# =========================================================
# 4. 构造滑窗
# =========================================================
def make_windows(lowmid_all: np.ndarray,
                 high_all: np.ndarray,
                 full_target_scaled: np.ndarray,
                 input_len: int,
                 horizon: int):
    """
    输入:
        lowmid_all:         (T1, N, K-1)
        high_all:           (T2, N, 1)
        full_target_scaled: (T3, N)

    输出:
        X_lowmid:   (samples, input_len, N, K-1)
        X_high:     (samples, input_len, N, 1)
        y_full:     (samples, horizon, N)
        y_lowmid:   (samples, horizon, N)
        y_high:     (samples, horizon, N)
    """

    # 先统一长度，避免某个 split 里 VMD 输出长度和目标长度不完全一致
    T = min(lowmid_all.shape[0], high_all.shape[0], full_target_scaled.shape[0])

    lowmid_all = lowmid_all[:T]
    high_all = high_all[:T]
    full_target_scaled = full_target_scaled[:T]

    # 低中频总和目标 / 高频目标
    lowmid_sum = lowmid_all.sum(axis=-1)   # (T, N)
    high_only = high_all[..., 0]           # (T, N)

    num_samples = T - input_len - horizon + 1
    if num_samples <= 0:
        raise ValueError(
            f"样本数<=0，请检查长度。"
            f"T={T}, input_len={input_len}, horizon={horizon}"
        )

    N = full_target_scaled.shape[1]
    lowmid_feat_dim = lowmid_all.shape[2]

    # 预分配，保证每个样本 shape 完全一致
    X_lowmid = np.zeros((num_samples, input_len, N, lowmid_feat_dim), dtype=np.float32)
    X_high = np.zeros((num_samples, input_len, N, 1), dtype=np.float32)
    y_full = np.zeros((num_samples, horizon, N), dtype=np.float32)
    y_lowmid = np.zeros((num_samples, horizon, N), dtype=np.float32)
    y_high = np.zeros((num_samples, horizon, N), dtype=np.float32)

    for i in tqdm(range(num_samples), desc="构造滑窗"):
        X_lowmid[i] = lowmid_all[i:i + input_len]
        X_high[i] = high_all[i:i + input_len]
        y_full[i] = full_target_scaled[i + input_len:i + input_len + horizon]
        y_lowmid[i] = lowmid_sum[i + input_len:i + input_len + horizon]
        y_high[i] = high_only[i + input_len:i + input_len + horizon]

    return X_lowmid, X_high, y_full, y_lowmid, y_high


# =========================================================
# 5. 处理单个 split
# =========================================================
def process_split(split_name: str,
                  raw_segment: np.ndarray,
                  scaler: StandardScaler,
                  cfg: Config):
    print(f"\n========== 处理 {split_name} ==========")

    segment_scaled = scaler.transform(raw_segment).astype(np.float32)
    print(f"{split_name} scaled shape:", segment_scaled.shape)

    lowmid_all, high_all, omega_all = decompose_segment_with_vmd(segment_scaled, cfg)

    print(f"{split_name} lowmid_all:", lowmid_all.shape)
    print(f"{split_name} high_all  :", high_all.shape)

    X_lowmid, X_high, y_full, y_lowmid, y_high = make_windows(
        lowmid_all=lowmid_all,
        high_all=high_all,
        full_target_scaled=segment_scaled,
        input_len=cfg.input_len,
        horizon=cfg.horizon
    )

    print(f"{split_name} X_lowmid :", X_lowmid.shape)
    print(f"{split_name} X_high   :", X_high.shape)
    print(f"{split_name} y_full   :", y_full.shape)
    print(f"{split_name} y_lowmid :", y_lowmid.shape)
    print(f"{split_name} y_high   :", y_high.shape)

    return {
        "X_lowmid": X_lowmid,
        "X_high": X_high,
        "y_full": y_full,
        "y_lowmid": y_lowmid,
        "y_high": y_high,
        "omega_sorted": omega_all
    }


# =========================================================
# 6. 主流程
# =========================================================
def main():
    output_dir = Path(CFG.output_dir)
    ensure_dir(output_dir)

    print("读取数据...")
    data = pd.read_csv(CFG.data_path).values.astype(np.float32)
    assert data.shape[1] == CFG.num_farms, f"列数应为 {CFG.num_farms}，实际是 {data.shape[1]}"
    print("原始数据形状:", data.shape)

    # ---------- 绘图目录 ----------
    figure_dir = Path(CFG.figure_dir)
    ensure_dir(figure_dir)

    # ---------- 固定颜色 ----------
    farm_colors = get_farm_colors(CFG.num_farms)

    # ---------- 图1：原始功率时间序列 ----------
    plot_raw_power_series(
        raw_data=data,
        cfg=CFG,
        figure_dir=figure_dir,
        farm_colors=farm_colors
    )

    # ---------- 局部图1：原始功率时间序列局部放大 ----------
    plot_raw_power_series_local(
        raw_data=data,
        cfg=CFG,
        figure_dir=figure_dir,
        farm_colors=farm_colors
    )

    # ---------- 时间顺序切分 ----------
    train_raw, val_raw, test_raw, train_end, val_end = split_raw_series(
        data,
        CFG.train_ratio,
        CFG.val_ratio
    )

    print("\n===== 原始数据划分 =====")
    print("train_raw:", train_raw.shape)
    print("val_raw  :", val_raw.shape)
    print("test_raw :", test_raw.shape)

    # ---------- 给 val / test 补上下文 ----------
    val_raw_with_context = extend_with_context(train_raw, val_raw, CFG.input_len)
    test_raw_with_context = extend_with_context(
        np.concatenate([train_raw, val_raw], axis=0),
        test_raw,
        CFG.input_len
    )

    print("\n===== 带上下文的划分 =====")
    print("train_raw         :", train_raw.shape)
    print("val_raw_with_ctx  :", val_raw_with_context.shape)
    print("test_raw_with_ctx :", test_raw_with_context.shape)

    # ---------- 只用训练集拟合 scaler ----------
    scaler = StandardScaler()
    scaler.fit(train_raw)

    np.save(output_dir / "scaler_mean.npy", scaler.mean_.astype(np.float32))
    np.save(output_dir / "scaler_scale.npy", scaler.scale_.astype(np.float32))

    # ---------- 图2：基于标准化完整序列的 VMD 分解展示图 ----------
    # 说明：这里仅用于第2章画图展示，不参与 train/val/test 的模型训练数据保存。
    data_scaled_for_plot = scaler.transform(data).astype(np.float32)

    modes_all_for_plot, omega_all_for_plot = decompose_full_scaled_for_plot(
        data_scaled=data_scaled_for_plot,
        cfg=CFG
    )

    np.save(figure_dir / "plot_omega_sorted_full.npy", omega_all_for_plot)

    plot_vmd_components_grid(
        modes_all=modes_all_for_plot,
        cfg=CFG,
        figure_dir=figure_dir,
        farm_colors=farm_colors
    )

    # ---------- 局部图2：一号风电场 VMD 局部分解 ----------
    plot_farm1_vmd_local_trend(
        data_scaled=data_scaled_for_plot,
        modes_all=modes_all_for_plot,
        cfg=CFG,
        figure_dir=figure_dir
    )

    # ---------- 分别处理 train / val / test ----------
    train_pack = process_split("train", train_raw, scaler, CFG)
    val_pack = process_split("val", val_raw_with_context, scaler, CFG)
    test_pack = process_split("test", test_raw_with_context, scaler, CFG)

    # ---------- 保存 train ----------
    np.save(output_dir / "train_X_lowmid.npy", train_pack["X_lowmid"])
    np.save(output_dir / "train_X_high.npy", train_pack["X_high"])
    np.save(output_dir / "train_y_full.npy", train_pack["y_full"])
    np.save(output_dir / "train_y_lowmid.npy", train_pack["y_lowmid"])
    np.save(output_dir / "train_y_high.npy", train_pack["y_high"])
    np.save(output_dir / "train_omega_sorted.npy", train_pack["omega_sorted"])

    # ---------- 保存 val ----------
    np.save(output_dir / "val_X_lowmid.npy", val_pack["X_lowmid"])
    np.save(output_dir / "val_X_high.npy", val_pack["X_high"])
    np.save(output_dir / "val_y_full.npy", val_pack["y_full"])
    np.save(output_dir / "val_y_lowmid.npy", val_pack["y_lowmid"])
    np.save(output_dir / "val_y_high.npy", val_pack["y_high"])
