def decompose_full_scaled_for_plot(data_scaled: np.ndarray, cfg: Config):
    """
    为绘图单独对完整标准化序列做一次 VMD 分解。
    注意：该函数只用于第2章展示 VMD 分解效果，不参与模型训练数据保存。

    输入:
        data_scaled: (T, N)

    输出:
        modes_all:  (T, N, K)
        omega_all:  (N, K)
    """
    T, N = data_scaled.shape

    modes_list = []
    omega_all = []

    print("\n开始为绘图进行完整序列 VMD 分解...")

    for farm in range(N):
        print(f"绘图分解 Farm {farm + 1}/{N}")

        signal = data_scaled[:, farm]

        u, u_hat, omega = VMD(
            signal,
            alpha=cfg.alpha,
            tau=cfg.tau,
            K=cfg.K,
            DC=cfg.DC,
            init=cfg.init,
            tol=cfg.tol
        )

        # u: (K, T) -> (T, K)
        u = u.T

        # 按最终中心频率从低到高排序
        omega_final = omega[-1]
        order = np.argsort(omega_final)
        omega_sorted = omega_final[order]
        u = u[:, order]

        modes_list.append(u.astype(np.float32))
        omega_all.append(omega_sorted.astype(np.float32))

    modes_all = np.stack(modes_list, axis=1)  # (T, N, K)
    omega_all = np.stack(omega_all, axis=0)  # (N, K)

    return modes_all, omega_all


def plot_vmd_components_grid(modes_all: np.ndarray, cfg: Config, figure_dir: Path, farm_colors):
    """
    图2：六个风电场 VMD 分解结果大图。
    3行2列，每个子图对应一个风电场；
    每个风电场内部从上到下依次排布低频、中频、高频分量。

    输入:
        modes_all: (T, N, K)
    """
    T, N, K = modes_all.shape
    x = np.arange(T)

    if K != 3:
        raise ValueError(f"当前绘图函数默认 K=3，但实际 K={K}")

    fig, axes = plt.subplots(3, 2, figsize=(16, 12), sharex=True)
    axes = axes.flatten()

    component_names = ["Low-frequency component", "Mid-frequency component", "High-frequency component"]

    for farm in range(N):
        ax = axes[farm]
        color = farm_colors[farm]

        # 为了让低/中/高在同一个子图中从上到下分开显示，增加垂直偏移量
        low = modes_all[:, farm, 0]
        mid = modes_all[:, farm, 1]
        high = modes_all[:, farm, 2]

        # 根据该风电场三个分量的幅值自动设置偏移距离
        all_abs_max = max(
            np.max(np.abs(low)),
            np.max(np.abs(mid)),
            np.max(np.abs(high)),
            1e-6
        )
        offset = all_abs_max * 2.5

        y_low = low + offset
        y_mid = mid
        y_high = high - offset

        ax.plot(x, y_low, color=color, linewidth=0.8)
        ax.plot(x, y_mid, color=color, linewidth=0.8)
        ax.plot(x, y_high, color=color, linewidth=0.8)

        # 标注低中高频位置
        ax.text(0.01, 0.82, component_names[0], transform=ax.transAxes, fontsize=9)
        ax.text(0.01, 0.50, component_names[1], transform=ax.transAxes, fontsize=9)
        ax.text(0.01, 0.18, component_names[2], transform=ax.transAxes, fontsize=9)

        ax.set_title(f"Farm {farm + 1}", fontsize=11)
        ax.grid(alpha=0.25)

        # 去掉 y 轴刻度，避免偏移后的数值干扰阅读
        ax.set_yticks([])

    # 如果子图数量多于风电场数量，隐藏多余子图
    for idx in range(N, len(axes)):
        axes[idx].axis("off")

    fig.suptitle("VMD Decomposition Results of Six Wind Farms", fontsize=15)
    fig.supxlabel("Time step")
    fig.supylabel("VMD components: low / mid / high")
    plt.tight_layout(rect=[0, 0, 1, 0.96])

    save_path = figure_dir / "fig2_2_vmd_components_grid.png"
    plt.savefig(save_path, dpi=300)
    plt.close()

    print(f"VMD 分解结果大图已保存: {save_path.resolve()}")

def get_local_slice(total_len: int, cfg: Config):
    """
    根据 cfg.local_start 和 cfg.local_len 获取局部绘图区间。
    """
    start = max(0, int(cfg.local_start))
    end = min(total_len, start + int(cfg.local_len))

    if end <= start:
        raise ValueError(
            f"局部绘图范围无效: start={start}, end={end}, total_len={total_len}"
        )

    return start, end


