# =========================================================
# 1. 配置
# =========================================================
@dataclass
class Config:
    data_path: str = "ningxia6.csv"
    output_dir: str = "vmd_data"
    figure_dir: str = "vmd_figures"

    input_len: int = 96
    horizon: int = 1
    num_farms: int = 6

    train_ratio: float = 0.7
    val_ratio: float = 0.1
    test_ratio: float = 0.2

    # VMD 参数
    K: int = 3
    alpha: int = 2000
    tau: int = 0
    DC: int = 0
    init: int = 1
    tol: float = 1e-7

    # 局部趋势图横轴范围
    local_start: int = 0
    local_len: int = 600


CFG = Config()


# =========================================================
# 2. 基础工具
# =========================================================
def ensure_dir(path: Path):
    path.mkdir(parents=True, exist_ok=True)


def save_json(obj, path: Path):
    with open(path, "w", encoding="utf-8") as f:
        json.dump(obj, f, ensure_ascii=False, indent=2)


def split_raw_series(data: np.ndarray, train_ratio: float, val_ratio: float):
    total_len = len(data)
    train_end = int(total_len * train_ratio)
    val_end = int(total_len * (train_ratio + val_ratio))

    train_raw = data[:train_end]
    val_raw = data[train_end:val_end]
    test_raw = data[val_end:]

    return train_raw, val_raw, test_raw, train_end, val_end


def extend_with_context(prev_raw: np.ndarray, curr_raw: np.ndarray, input_len: int):
    context = prev_raw[-input_len:]
    return np.concatenate([context, curr_raw], axis=0)


