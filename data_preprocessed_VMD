def get_farm_colors(num_farms: int):
    """
    为 6 个风电场固定颜色。
    图1和图2共用该颜色表，保证同一风电场颜色一致。
    """
    base_colors = [
        "#1f77b4",  # Farm 1 - 蓝
        "#ff7f0e",  # Farm 2 - 橙
        "#2ca02c",  # Farm 3 - 绿
        "#d62728",  # Farm 4 - 红
        "#9467bd",  # Farm 5 - 紫
        "#8c564b",  # Farm 6 - 棕
    ]
    return base_colors[:num_farms]


def plot_raw_power_series(raw_data: np.ndarray, cfg: Config, figure_dir: Path, farm_colors):
    """
    图1：原始功率时间序列图。
    直接使用原始数据 raw_data 作图，不使用标准化数据。

    输入:
